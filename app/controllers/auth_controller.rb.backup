class AuthController < ApplicationController
  include DeviceAuthenticationConcern
  include AuthenticationConcern
  
  skip_before_action :authenticate_user!, only: [:login, :phone_login, :verify_code, :verify_guid, :verify_guid_code, :update_handle]
  skip_before_action :verify_authenticity_token, only: [:phone_login, :verify_code, :verify_guid, :verify_guid_code]
  layout 'auth'
  
def logout
  device = current_device
  handle = device&.user&.handle
  database_path = device&.device_database&.path

  if device && database_path
    # For any known device (verified or not), preserve device info but mark as needing verification
    update_device_database(device, {
      verified: false,
      last_sync: Time.current.iso8601
    })
    
    # Clear session but keep database path for GUID flow
    cookies.delete(:device_token, domain: determine_cookie_domain)
    cookies.delete(:_superapp_session, domain: determine_cookie_domain)
    
    storage_data = {
      device_database_path: database_path,
      handle: handle,
      verified: false,
      guid_enabled: true,
      sync_time: Time.current.iso8601
    }
    
    response.headers['X-Set-Storage'] = storage_data.to_json
    reset_session
    
    render json: {
      status: 'success',
      handle: handle,
      database_path: database_path,
      verified: false,
      redirect_to: '/login'
    }
  else
    # Only clear everything if we somehow got a corrupted state
    cookies.delete(:device_database_path, domain: determine_cookie_domain)
    cookies.delete(:device_token, domain: determine_cookie_domain)
    reset_session
    
    render json: {
      status: 'error',
      message: 'Invalid device state detected, please log in again',
      redirect_to: '/login'
    }
  end
end

def logout
  device = current_device
  handle = device&.user&.handle
  database_path = device&.device_database&.path

  if device && database_path
    # For any known device (verified or not), preserve device info but mark as needing verification
    update_device_database(device, {
